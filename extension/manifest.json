{
  "manifest_version": 3,
  "name": "ResumeAI - Tailor Resume to Any Job",
  "version": "1.0.0",
  "description": "One-click resume tailoring for LinkedIn, Indeed, and Naukri job listings. Get ATS-optimized resumes in 30 seconds.",
  "permissions": [
    "activeTab",
    "storage",
    "cookies"
  ],
  "host_permissions": [
    "https://resume-ai-tan.vercel.app/*",
    "https://www.linkedin.com/*",
    "https://linkedin.com/*",
    "https://www.indeed.com/*",
    "https://indeed.com/*",
    "https://in.indeed.com/*",
    "https://www.naukri.com/*",
    "https://naukri.com/*"
  ],
  "action": {
    "default_popup": "src/popup/index.html",
    "default_icon": {
      "16": "assets/icon-16.png",
      "32": "assets/icon-32.png",
      "48": "assets/icon-48.png",
      "128": "assets/icon-128.png"
    }
  },
  "background": {
    "service_worker": "src/background/service-worker.ts",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": [
        "https://www.linkedin.com/jobs/*",
        "https://www.linkedin.com/job/*",
        "https://linkedin.com/jobs/*"
      ],
      "js": ["src/content/linkedin.ts"],
      "run_at": "document_idle"
    },
    {
      "matches": [
        "https://www.indeed.com/*",
        "https://indeed.com/*",
        "https://in.indeed.com/*"
      ],
      "js": ["src/content/indeed.ts"],
      "run_at": "document_idle"
    },
    {
      "matches": [
        "https://www.naukri.com/job-listings-*",
        "https://www.naukri.com/job/*",
        "https://naukri.com/job-listings-*",
        "https://naukri.com/job/*"
      ],
      "js": ["src/content/naukri.ts"],
      "run_at": "document_idle"
    }
  ],
  "icons": {
    "16": "assets/icon-16.png",
    "32": "assets/icon-32.png",
    "48": "assets/icon-48.png",
    "128": "assets/icon-128.png"
  }
}
